# ── TAP2DINE ENVIRONMENT VARIABLES ────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git!

# ── JWT AUTH (items #1-3) ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=your-64-char-hex-secret-here
JWT_EXPIRE_HOURS=8

# ── ADMIN CREDENTIALS (items #2-3) ───────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'YourPass', bcrypt.gensalt(12)).decode())"
ADMIN_PASSWORD_HASH=$2b$12$ioQwm8XsX5uiPFEri7xBtO6fsMKMvP1dOxsMBqkZGsziFY49DHGoO
# Fallback plain-text (only if ADMIN_PASSWORD_HASH is not set)
# ADMIN_PASSWORD=Admin@tap2

# ── CORS (item #11) ───────────────────────────────────────────────────────────
FRONTEND_URL=https://tap2dine-ten.vercel.app

# ── RAZORPAY ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── GEMINI AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── DATABASE (item #12) ───────────────────────────────────────────────────────
# SQLite default (Vercel writes to /tmp)
# For production switch to PostgreSQL:
# DATABASE_URL=postgresql://user:pass@host:5432/tap2dine
