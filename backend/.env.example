# ── Razorpay API Keys ──────────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
# Use TEST keys (rzp_test_...) for development, LIVE keys for production.
#
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env
#   2. Paste your keys below
#   3. Re-run start.bat — keys are auto-loaded
#
# ⚠️  NEVER commit .env to Git (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME_WITH_YOUR_SECRET
